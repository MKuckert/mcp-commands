      "hidden": true,
      "model": "apple/apple-on-device",
    },
    "summary": {
      "mode": "primary",
      "hidden": true,
      "model": "apple/apple-on-device",
    },
  },
  "mcp": {
    "context7": {
      "type": "remote",
