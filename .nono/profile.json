{
  "$schema": "/Users/mkuckert/.config/nono/nono-profile.schema.json",
  "extends": "opencode",
  "meta": {
    "author": "Martin Kuckert",
    "name": "opencode-mcp-commands"
  },
  "groups": {
    "include": ["go_runtime", "go_runtime_macos"]
  },
  "workdir": {
    "access": "readwrite"
  },
  "filesystem": {
    "read_file": [
      "~/.aliases",
      "~/.bash_profile",
      "~/.bash_prompt",
      "~/.editorconfig",
      "~/.extra",
      "~/.exports",
      "~/.gitconfig-agents",
      "~/.gitconfig-private",
      "~/.gitconfig-work",
      "~/.gitignore",
      "~/.path",
      "~/.tigrc",
      "~/.vimrc",
      "/opt/homebrew/bin/go"
    ],
    "read": [
      "~/.cache",
      "~/.config",
      "~/.config/nono",
      "~/private",
      "~/private/dev"
    ],
    "allow": [
      "~/.npm/_cacache/tmp",
      "~/.go",
      "~/private/dev/mcp-commands",
      "/opt/homebrew/bin"
    ],
    "deny": ["~/.gitconfig"]
  },
  "network": {
    "allow_domain": ["localhost", "proxy.golang.org", "sum.golang.org"],
    "allow_port": [11438, 12010]
  },
  "environment": {
    "allow_vars": ["HOME", "SHELL"],
    "set_vars": {
      "GIT_CONFIG_GLOBAL": "~/.gitconfig-agents",
      "GOPATH": "~/.go"
    }
  },
  "session_hooks": {
    "before": {
      "script": "/Users/mkuckert/private/dev/mcp-commands/.nono/hooks/before.sh"
    },
    "after": {
      "script": "/Users/mkuckert/private/dev/mcp-commands/.nono/hooks/after.sh"
    }
  }
}
